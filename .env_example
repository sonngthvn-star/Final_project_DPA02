---
### The `.env_example` File

```

# ==============================================================================
# 1. DATABASE CONNECTIVITY (Shared by ETL & Dashboard)
# ==============================================================================
# DB_HOST: 
# - Use 'postgres_dw' for Docker
# - Use 'localhost' for manual Windows runs
DB_HOST=postgres_dw
DB_PORT_INTERNAL=5432
DB_PORT_EXTERNAL=5433
DB_ROOT_NAME=postgres

# Target Database Credentials (The Medallion Store)
TARGET_POSTGRES_USER=postgres
TARGET_POSTGRES_PASSWORD=your_password_here
TARGET_POSTGRES_DB=air_quality_db

# Legacy variables (keeping for backward compatibility with older scripts)
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=air_quality_db

# ==============================================================================
# 2. AIRFLOW INFRASTRUCTURE (ETL Orchestration)
# ==============================================================================
AIRFLOW_IMAGE=apache/airflow:2.8.1
AIRFLOW_UID=50000

# Metadata Database (Internal Airflow Use Only)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# ==============================================================================
# 3. API CREDENTIALS (NEW)
# ==============================================================================
# Get your key at https://openweathermap.org/api/air-pollution
OWM_API_KEY=your_owm_api_key_here

# ==============================================================================
# 4. DASHBOARD SETTINGS (Flask Web Server)
# ==============================================================================
FLASK_APP=dashboard/myproject.py
FLASK_ENV=development
# These match your previous .env_airquality
HOST=127.0.0.1
PORT=8000

# ==============================================================================
# 5. SYSTEM PATHS
# ==============================================================================
LOG_DIR=./logs